# ---------------------------------------------------------------------------
# Variables de entorno — copiar a .env.local (dev) o setear en Railway (prod).
# Ninguna trae valor real acá; este archivo SÍ se commitea.
# ---------------------------------------------------------------------------

# --- Base de datos (Postgres / Railway) ---
# DATABASE_URL: conexión de RUNTIME, va a través de PgBouncer (pool mode =
# transaction). DEBE llevar `?pgbouncer=true&connection_limit=1` para que Prisma
# desactive los prepared statements y no pelee con el bouncer.
DATABASE_URL=postgresql://user:password@host:6432/dbname?pgbouncer=true&connection_limit=1
# DIRECT_URL: conexión DIRECTA a Postgres, SIN pgbouncer (sin `?pgbouncer=true`).
# La usa `prisma migrate` / introspección, que necesitan session-mode (advisory
# locks, DDL con prepared statements).
DIRECT_URL=postgresql://user:password@host:5432/dbname

# --- Auth (next-auth v5) ---
# Generar con: openssl rand -base64 32
NEXTAUTH_SECRET=
# URL pública del sitio (ej: https://traveloz.com.uy)
NEXTAUTH_URL=http://localhost:3000
APP_URL=http://localhost:3000

# --- Owner admin protegido (scripts/ensure-protected-admin.mjs) ---
PROTECTED_ADMIN_EMAIL=
PROTECTED_ADMIN_NAME=
PROTECTED_ADMIN_PASSWORD=

# --- Storage S3-compatible (Tigris / Railway / MinIO) ---
STORAGE_ENDPOINT=
STORAGE_REGION=auto
STORAGE_BUCKET=
STORAGE_ACCESS_KEY_ID=
STORAGE_SECRET_ACCESS_KEY=
# true para MinIO/local:
STORAGE_FORCE_PATH_STYLE=false
# Aliases legacy AWS_* (algunos scripts los leen; apuntar al mismo bucket):
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=auto
AWS_ENDPOINT_URL=
AWS_S3_BUCKET_NAME=

# --- Email (Resend) — sin API key, los mails se loguean a consola ---
RESEND_API_KEY=
EMAIL_FROM="TravelOz <no-reply@traveloz.com.uy>"

# --- Reglas de negocio (opcionales, tienen defaults) ---
# Factor mínimo de markup permitido al guardar precios:
MIN_MARKUP_FACTOR=
# Factor que dispara warning (sin bloquear):
WARN_MARKUP_FACTOR=

# --- Observabilidad ---
# debug | info | warn | error (default: info)
LOG_LEVEL=

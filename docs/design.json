      "deleteShake": { "animate": { "x": [0, -4, 4, -2, 2, 0] }, "duration": 0.4, "delay": 0.3 },
      "skeleton": { "backgroundSize": "200% 100%", "background": "linear-gradient(90deg, rgba(236,237,245,0.6) 0%, rgba(255,255,255,0.4) 50%, rgba(236,237,245,0.6) 100%)", "animation": "shimmer 1.8s ease-in-out infinite" }

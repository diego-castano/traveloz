{
  "$schema": "traveloz-design-system",
  "$version": "3.0.0",
  "$codename": "Liquid Horizon",
  "$description": "Design System premium para el panel admin de TravelOz y DestinoIcono. Glassmorphism + Liquid Glass + Claymorphism + Apple-like interactions. Sidebar violeta→negro. Sistema unificado con branding intercambiable.",
  "$author": "Latitud Nómade",
  "$date": "2026-03-15",
  "$stack": "Next.js 14 + Tailwind CSS + Framer Motion + Prisma + PostgreSQL",
  "$philosophy": "Un backend que se siente como un producto Apple: cada interacción tiene peso, cada transición tiene propósito, cada superficie respira.",

  "brands": {
    "traveloz": {
      "name": "TravelOz",
      "slug": "traveloz",
      "tagline": "#ExperienciaOZ",
      "logo": "/assets/brands/traveloz-logo.webp",
      "logoWhite": "/assets/brands/traveloz-logo-white.webp",
      "favicon": "/assets/brands/traveloz-favicon.svg",
      "sidebarStyle": "glass-dark-violet",
      "sidebarGradient": "linear-gradient(180deg, rgba(108,43,217,0.95) 0%, rgba(68,20,150,0.97) 40%, rgba(15,8,30,0.99) 100%)",
      "sidebarBlur": "24px",
      "sidebarGlow": "4px 0 24px rgba(108,43,217,0.08)",
      "sidebarTopGlow": "radial-gradient(ellipse at 50% 0%, rgba(139,92,246,0.12) 0%, transparent 70%)",
      "loginBackground": "radial-gradient(ellipse at 30% 20%, rgba(139,92,246,0.35) 0%, transparent 50%), radial-gradient(ellipse at 70% 80%, rgba(59,191,173,0.2) 0%, transparent 50%), linear-gradient(135deg, #1A1A2E 0%, #0F0F1E 100%)",
      "loginMeshGradient": true,
      "accentPrimary": "violet",
      "accentSecondary": "teal",
      "brandGlow": "rgba(139,92,246,0.12)",
      "brandGlowTeal": "rgba(59,191,173,0.08)"
    },
    "destinoicono": {
      "name": "DestinoIcono",
      "slug": "destinoicono",
      "tagline": "Tu destino, tu ícono",
      "logo": "/assets/brands/destinoicono-logo.webp",
      "logoWhite": "/assets/brands/destinoicono-logo-white.webp",
      "favicon": "/assets/brands/destinoicono-favicon.svg",
      "sidebarStyle": "glass-dark-navy",
      "sidebarGradient": "linear-gradient(180deg, rgba(26,58,92,0.95) 0%, rgba(15,36,64,0.97) 40%, rgba(6,16,32,0.99) 100%)",
      "sidebarBlur": "24px",
      "sidebarGlow": "4px 0 24px rgba(26,58,92,0.08)",
      "sidebarTopGlow": "radial-gradient(ellipse at 50% 0%, rgba(107,139,174,0.1) 0%, transparent 70%)",
      "loginBackground": "radial-gradient(ellipse at 30% 20%, rgba(26,58,92,0.4) 0%, transparent 50%), radial-gradient(ellipse at 70% 80%, rgba(59,191,173,0.25) 0%, transparent 50%), linear-gradient(135deg, #0A1628 0%, #060E18 100%)",
      "loginMeshGradient": true,
      "accentPrimary": "navy",
      "accentSecondary": "teal",
      "brandGlow": "rgba(26,58,92,0.15)",
      "brandGlowTeal": "rgba(59,191,173,0.1)"
    }
  },

  "primitives": {
    "colors": {
      "violet": {
        "50": "#F5F3FF", "100": "#EDE9FE", "200": "#DDD6FE", "300": "#C4B5FD",
        "400": "#A78BFA", "500": "#8B5CF6", "600": "#7C3AED", "700": "#6C2BD9",
        "800": "#5B21B6", "900": "#4C1D95", "950": "#2E1065"
      },
      "teal": {
        "50": "#E6F8F5", "100": "#C0EFE8", "200": "#8DE5D8", "300": "#5AD5C4",
        "400": "#3BBFAD", "500": "#2A9E8E", "600": "#1F7D70", "700": "#165C53",
        "800": "#0D3B35", "900": "#061F1C"
      },
      "red": {
        "50": "#FFF5F6", "100": "#FFE0E3", "200": "#FFB8BF", "300": "#FF8A95",
        "400": "#E74C5F", "500": "#CC2030", "600": "#A8192A", "700": "#7A1420"
      },
      "navy": {
        "50": "#F0F4F8", "100": "#D9E2EC", "200": "#BCCCDC", "300": "#9FB3C8",
        "400": "#6B8BAE", "500": "#1A3A5C", "600": "#153050", "700": "#0F2440"
      },
      "neutral": {
        "0": "#FFFFFF", "25": "#FAFBFE", "50": "#F5F6FA", "100": "#ECEDF5",
        "150": "#E4E6F2", "200": "#D2D5E5", "300": "#B0B4CD", "400": "#8A8DB5",
        "500": "#6B6F99", "600": "#3D4066", "700": "#2D2F4D", "800": "#232342",
        "900": "#1A1A2E", "950": "#111124"
      },
      "green": {
        "50": "#EDFAF3", "100": "#C5F0DA", "200": "#82DFAD", "300": "#4DCE8A",
        "400": "#2EAD6B", "500": "#1F8A54", "600": "#166B40"
      },
      "orange": {
        "50": "#FEF5EB", "100": "#FDE5CC", "200": "#F9C88A", "300": "#F2A94D",
        "400": "#E8913A", "500": "#D07520", "600": "#A85C18"
      },
      "yellow": {
        "50": "#FFFBEB", "100": "#FFF3C4", "200": "#FCE588", "300": "#FADB5F",
        "400": "#F0C000", "500": "#D4A800"
      },
      "blue": {
        "50": "#EBF5FF", "100": "#D0E8FF", "200": "#A3D1FF", "300": "#5EAAFF",
        "400": "#2B8AFF", "500": "#0066E6"
      }
    },
    "typography": {
      "fontFamilies": {
        "display": "'Playfair Display', Georgia, serif",
        "body": "'DM Sans', -apple-system, BlinkMacSystemFont, sans-serif",
        "mono": "'JetBrains Mono', 'SF Mono', 'Fira Code', monospace"
      },
      "fontWeights": { "regular": 400, "medium": 500, "semibold": 600, "bold": 700 },
      "fontSizes": {
        "2xs": "10px", "xs": "11px", "sm": "12.5px", "base": "14px", "md": "15px",
        "lg": "16px", "xl": "18px", "2xl": "20px", "3xl": "24px", "4xl": "28px", "5xl": "36px"
      },
      "lineHeights": { "tight": 1.25, "snug": 1.4, "normal": 1.6, "relaxed": 1.72 },
      "letterSpacing": { "tighter": "-0.5px", "tight": "-0.3px", "normal": "0", "wide": "0.3px", "caps": "1.8px" }
    },
    "spacing": {
      "0": "0px", "0.5": "2px", "1": "4px", "1.5": "6px", "2": "8px", "2.5": "10px",
      "3": "12px", "4": "16px", "5": "20px", "6": "24px", "7": "28px", "8": "32px",
      "10": "40px", "12": "48px", "16": "64px", "20": "80px"
    },
    "radii": {
      "none": "0px", "xs": "4px", "sm": "6px", "md": "8px", "lg": "12px", "xl": "14px",
      "2xl": "16px", "3xl": "20px", "4xl": "24px", "pill": "9999px"
    },
    "breakpoints": { "sm": "640px", "md": "768px", "lg": "1024px", "xl": "1280px", "2xl": "1536px" },
    "zIndex": { "hide": -1, "base": 0, "raised": 1, "dropdown": 10, "sticky": 20, "overlay": 30, "modal": 40, "popover": 50, "toast": 60, "sidebar": 100 }
  },

  "glass": {
    "_note": "Corazón visual del design system — sistema unificado de superficies glass",

    "materials": {
      "frosted": {
        "_note": "Glassmorphism clásico — cards, modals, dropdowns",
        "background": "rgba(255,255,255,0.72)",
        "backdropFilter": "blur(20px) saturate(180%)",
        "border": "1px solid rgba(255,255,255,0.25)",
        "borderBottom": "1px solid rgba(255,255,255,0.12)",
        "boxShadow": "0 8px 32px rgba(26,26,46,0.06), 0 1px 3px rgba(26,26,46,0.04), inset 0 1px 0 rgba(255,255,255,0.5)",
        "topAccent": "linear-gradient(90deg, transparent 0%, rgba(139,92,246,0.12) 30%, rgba(59,191,173,0.12) 70%, transparent 100%)",
        "breatheAnimation": "breathe 8s ease-in-out infinite"
      },
      "frostedSubtle": {
        "_note": "Glass suave — badges, chips, sub-sections dentro de cards",
        "background": "rgba(255,255,255,0.45)",
        "backdropFilter": "blur(12px) saturate(150%)",
        "border": "1px solid rgba(255,255,255,0.2)",
        "boxShadow": "0 2px 8px rgba(26,26,46,0.03)"
      },
      "frostedDark": {
        "_note": "Glass oscuro — sidebar, tooltips, dropdowns dark",
        "background": "rgba(26,26,46,0.78)",
        "backdropFilter": "blur(24px) saturate(180%)",
        "border": "1px solid rgba(255,255,255,0.08)",
        "boxShadow": "0 12px 40px rgba(0,0,0,0.25), inset 0 1px 0 rgba(255,255,255,0.06)"
      },
      "liquid": {
        "_note": "Liquid Glass — efecto lente/refracción para stat cards, modals, hero elements",
        "background": "rgba(255,255,255,0.55)",
        "backdropFilter": "blur(30px) saturate(200%) brightness(1.05)",
        "border": "1px solid rgba(255,255,255,0.35)",
        "borderTop": "1px solid rgba(255,255,255,0.6)",
        "boxShadow": "0 8px 32px rgba(26,26,46,0.08), 0 2px 6px rgba(26,26,46,0.04), inset 0 2px 0 rgba(255,255,255,0.4), inset 0 -1px 0 rgba(255,255,255,0.1)",
        "pseudoSheen": {
          "_note": "::after para brillo de superficie líquida",
          "background": "linear-gradient(105deg, rgba(255,255,255,0.3) 0%, transparent 30%, transparent 70%, rgba(255,255,255,0.08) 100%)"
        },
        "pseudoConicGlow": {
          "_note": "::before para glow rotatorio sutil al hover",
          "background": "conic-gradient(from 180deg, transparent 0%, rgba(139,92,246,0.06) 30%, transparent 60%)",
          "animation": "subtleRotate 10s linear infinite"
        },
        "svgFilter": {
          "filterId": "liquid-refraction",
          "feTurbulence": { "type": "fractalNoise", "baseFrequency": "0.015", "numOctaves": 3 },
          "feDisplacementMap": { "scale": 6, "xChannelSelector": "R", "yChannelSelector": "G" }
        }
      },
      "liquidHover": {
        "_note": "Estado hover del Liquid Glass",
        "background": "rgba(255,255,255,0.65)",
        "backdropFilter": "blur(34px) saturate(210%) brightness(1.08)",
        "boxShadow": "0 20px 50px rgba(26,26,46,0.12), 0 0 30px rgba(139,92,246,0.06), inset 0 2px 0 rgba(255,255,255,0.6)",
        "borderColor": "rgba(139,92,246,0.15)",
        "transform": "translateY(-5px) scale(1.01)",
        "transition": "all 0.5s cubic-bezier(0.34, 1.56, 0.64, 1)"
      },
      "liquidModal": {
        "_note": "Liquid Glass potenciado para modals",
        "background": "rgba(255,255,255,0.58)",
        "backdropFilter": "blur(40px) saturate(220%) brightness(1.08)",
        "border": "1px solid rgba(255,255,255,0.4)",
        "borderTop": "1px solid rgba(255,255,255,0.65)",
        "boxShadow": "0 40px 80px rgba(26,26,46,0.18), 0 16px 32px rgba(108,43,217,0.06), inset 0 2px 0 rgba(255,255,255,0.5)",
        "topAccent": "linear-gradient(90deg, transparent, rgba(139,92,246,0.2), rgba(59,191,173,0.15), transparent)"
      }
    },

    "clay": {
      "_note": "Claymorphism — botones primarios, CTAs, badges interactivos, pagination activa",
      "base": {
        "background": "linear-gradient(145deg, rgba(255,255,255,0.9) 0%, rgba(236,237,245,0.9) 100%)",
        "boxShadow": "8px 8px 20px rgba(26,26,46,0.08), -4px -4px 12px rgba(255,255,255,0.9), inset 0 2px 0 rgba(255,255,255,0.7), inset 0 -2px 4px rgba(26,26,46,0.03)"
      },
      "button": {
        "rest": { "boxShadow": "6px 6px 16px rgba(26,26,46,0.1), -3px -3px 10px rgba(255,255,255,0.85), inset 0 1px 0 rgba(255,255,255,0.6)", "transform": "translateY(0)" },
        "hover": { "boxShadow": "8px 8px 22px rgba(26,26,46,0.12), -4px -4px 14px rgba(255,255,255,0.9), inset 0 2px 0 rgba(255,255,255,0.7)", "transform": "translateY(-1px)" },
        "active": { "boxShadow": "2px 2px 8px rgba(26,26,46,0.1), -1px -1px 4px rgba(255,255,255,0.7), inset 0 2px 6px rgba(26,26,46,0.06)", "transform": "translateY(1px) scale(0.98)" }
      },
      "colored": {
        "teal": {
          "background": "linear-gradient(145deg, #45D4C0 0%, #2A9E8E 100%)",
          "boxShadow": "6px 6px 16px rgba(42,158,142,0.25), -3px -3px 10px rgba(69,212,192,0.3), inset 0 1px 0 rgba(255,255,255,0.35)",
          "color": "#FFFFFF",
          "sheenGradient": "linear-gradient(105deg, transparent 40%, rgba(255,255,255,0.15) 45%, rgba(255,255,255,0.25) 50%, rgba(255,255,255,0.15) 55%, transparent 60%)"
        },
        "red": {
          "background": "linear-gradient(145deg, #E74C5F 0%, #CC2030 100%)",
          "boxShadow": "6px 6px 16px rgba(204,32,48,0.25), -3px -3px 10px rgba(231,76,95,0.3), inset 0 1px 0 rgba(255,255,255,0.25)",
          "color": "#FFFFFF"
        },
        "violet": {
          "background": "linear-gradient(145deg, #A78BFA 0%, #7C3AED 100%)",
          "boxShadow": "6px 6px 16px rgba(124,58,237,0.25), -3px -3px 10px rgba(167,139,250,0.3), inset 0 1px 0 rgba(255,255,255,0.25)",
          "color": "#FFFFFF"
        },
        "navy": {
          "background": "linear-gradient(145deg, #2A5080 0%, #1A3A5C 100%)",
          "boxShadow": "6px 6px 16px rgba(26,58,92,0.3), -3px -3px 10px rgba(42,80,128,0.25), inset 0 1px 0 rgba(255,255,255,0.15)",
          "color": "#FFFFFF"
        }
      }
    },

    "noise": {
      "opacity": 0.025,
      "mixBlendMode": "overlay",
      "backgroundSvg": "data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.65' numOctaves='3' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E"
    },

    "meshGradient": {
      "animation": "meshFloat 20s ease-in-out infinite alternate",
      "keyframes": { "0%": "0% 0%, 100% 0%, 50% 100%", "50%": "100% 100%, 0% 50%, 80% 20%", "100%": "50% 0%, 50% 100%, 0% 50%" }
    }
  },

  "shadows": {
    "elevation": {
      "0": "none",
      "1": "0 1px 2px rgba(26,26,46,0.04)",
      "2": "0 1px 3px rgba(26,26,46,0.06), 0 1px 2px rgba(26,26,46,0.04)",
      "4": "0 4px 8px -1px rgba(26,26,46,0.06), 0 2px 4px -2px rgba(26,26,46,0.04)",
      "8": "0 8px 16px -2px rgba(26,26,46,0.08), 0 4px 6px -4px rgba(26,26,46,0.04)",
      "16": "0 16px 32px -4px rgba(26,26,46,0.1), 0 6px 12px -6px rgba(26,26,46,0.05)",
      "24": "0 24px 48px -8px rgba(26,26,46,0.12), 0 8px 16px -8px rgba(26,26,46,0.06)",
      "32": "0 32px 64px -12px rgba(26,26,46,0.15), 0 12px 24px -8px rgba(26,26,46,0.08)"
    },
    "glow": {
      "violet": "0 0 20px rgba(139,92,246,0.25), 0 0 60px rgba(139,92,246,0.08)",
      "teal": "0 0 20px rgba(59,191,173,0.25), 0 0 60px rgba(59,191,173,0.08)",
      "red": "0 0 20px rgba(204,32,48,0.2), 0 0 60px rgba(204,32,48,0.06)",
      "success": "0 0 16px rgba(46,173,107,0.2)",
      "danger": "0 0 16px rgba(231,76,95,0.2)",
      "warning": "0 0 16px rgba(232,145,58,0.2)"
    },
    "focus": {
      "teal": "0 0 0 2px rgba(255,255,255,0.8), 0 0 0 4px rgba(59,191,173,0.4)",
      "violet": "0 0 0 2px rgba(255,255,255,0.8), 0 0 0 4px rgba(139,92,246,0.3)",
      "danger": "0 0 0 2px rgba(255,255,255,0.8), 0 0 0 4px rgba(231,76,95,0.3)"
    },
    "inner": {
      "subtle": "inset 0 2px 4px rgba(26,26,46,0.04)",
      "medium": "inset 0 2px 6px rgba(26,26,46,0.06), inset 0 -1px 0 rgba(255,255,255,0.5)"
    }
  },

  "animations": {
    "_note": "Sistema completo Apple-like con Framer Motion springs + CSS keyframes",

    "springs": {
      "snappy": { "type": "spring", "stiffness": 500, "damping": 30, "mass": 0.8 },
      "gentle": { "type": "spring", "stiffness": 260, "damping": 25, "mass": 1 },
      "bouncy": { "type": "spring", "stiffness": 400, "damping": 20, "mass": 0.8 },
      "slow": { "type": "spring", "stiffness": 150, "damping": 25, "mass": 1.2 },
      "micro": { "type": "spring", "stiffness": 600, "damping": 35, "mass": 0.5 }
    },
    "easings": {
      "default": "cubic-bezier(0.25, 0.1, 0.25, 1.0)",
      "easeOut": "cubic-bezier(0.16, 1, 0.3, 1)",
      "spring": "cubic-bezier(0.34, 1.56, 0.64, 1)",
      "bounce": "cubic-bezier(0.68, -0.55, 0.265, 1.55)",
      "smooth": "cubic-bezier(0.45, 0, 0.55, 1)"
    },
    "durations": { "instant": "50ms", "fast": "120ms", "normal": "200ms", "medium": "300ms", "slow": "450ms", "entrance": "350ms", "exit": "200ms" },

    "cssKeyframes": {
      "fadeSlideIn": { "from": { "opacity": 0, "transform": "translateY(12px)", "filter": "blur(4px)" }, "to": { "opacity": 1, "transform": "translateY(0)", "filter": "blur(0)" } },
      "liquidFloat": { "0%,100%": { "transform": "translateY(0) scale(1)" }, "50%": { "transform": "translateY(-3px) scale(1.003)" } },
      "sheenSlide": { "0%": { "backgroundPosition": "-200% 0" }, "100%": { "backgroundPosition": "200% 0" } },
      "glowPulse": { "0%,100%": { "boxShadow": "0 8px 32px rgba(26,26,46,0.06), 0 0 0 0 rgba(139,92,246,0)" }, "50%": { "boxShadow": "0 8px 32px rgba(26,26,46,0.06), 0 0 20px rgba(139,92,246,0.06)" } },
      "borderGlow": { "0%,100%": { "borderColor": "rgba(255,255,255,0.25)" }, "50%": { "borderColor": "rgba(139,92,246,0.15)" } },
      "subtleRotate": { "0%": { "filter": "hue-rotate(0deg)" }, "100%": { "filter": "hue-rotate(3deg)" } },
      "breathe": { "0%,100%": { "opacity": 0.72 }, "50%": { "opacity": 0.78 } },
      "sidebarGlow": { "0%,100%": { "boxShadow": "4px 0 24px rgba(108,43,217,0.08)" }, "50%": { "boxShadow": "4px 0 32px rgba(108,43,217,0.14)" } },
      "shimmer": { "0%": { "backgroundPosition": "-200% 0" }, "100%": { "backgroundPosition": "200% 0" } },
      "meshFloat": { "0%": { "backgroundPosition": "0% 0%, 100% 0%, 50% 100%" }, "50%": { "backgroundPosition": "100% 100%, 0% 50%, 80% 20%" }, "100%": { "backgroundPosition": "50% 0%, 50% 100%, 0% 50%" } },
      "pulseGlow": { "0%,100%": { "boxShadow": "0 0 0 0 rgba(59,191,173,0.4)" }, "50%": { "boxShadow": "0 0 0 8px rgba(59,191,173,0)" } },
      "arrowPulse": { "0%,100%": { "transform": "translateX(0)" }, "50%": { "transform": "translateX(3px)" } },
      "microBounce": { "0%,100%": { "transform": "scale(1)" }, "50%": { "transform": "scale(1.05)" } },
      "toastIn": { "from": { "opacity": 0, "transform": "translateX(80px) scale(0.9)", "filter": "blur(4px)" }, "to": { "opacity": 1, "transform": "translateX(0) scale(1)", "filter": "blur(0)" } },
      "modalIn": { "from": { "opacity": 0, "transform": "scale(0.88) translateY(30px)", "filter": "blur(8px)" }, "to": { "opacity": 1, "transform": "scale(1) translateY(0)", "filter": "blur(0)" } },
      "dropdownIn": { "from": { "opacity": 0, "transform": "scale(0.92) translateY(-8px)", "filter": "blur(4px)" }, "to": { "opacity": 1, "transform": "scale(1) translateY(0)", "filter": "blur(0)" } },
      "overlayIn": { "from": { "opacity": 0, "backdropFilter": "blur(0)" }, "to": { "opacity": 1, "backdropFilter": "blur(8px)" } },
      "checkPop": { "from": { "transform": "scale(0)" }, "to": { "transform": "scale(1)" } }
    },

    "interactions": {
      "buttonPress": {
        "whileTap": { "scale": 0.96 },
        "whileHover": { "scale": 1.01, "y": -1 },
        "springConfig": "snappy",
        "sheenOnHover": true
      },
      "cardHover": {
        "whileHover": { "y": -5, "scale": 1.01 },
        "whileTap": { "scale": 0.995, "y": 0 },
        "springConfig": "gentle",
        "liquidFloatAnimation": "liquidFloat 6s ease-in-out infinite",
        "borderGlowAnimation": "borderGlow 8s ease-in-out infinite",
        "conicGlowOnHover": true
      },
      "rowHover": {
        "whileHover": {
          "background": "linear-gradient(90deg, rgba(139,92,246,0.03) 0%, rgba(59,191,173,0.04) 50%, rgba(139,92,246,0.02) 100%)",
          "boxShadow": "inset 0 0 0 1px rgba(139,92,246,0.06), 0 2px 8px rgba(26,26,46,0.02)"
        },
        "duration": 0.2,
        "easing": "easeOut"
      },
      "rowSelected": {
        "background": "linear-gradient(90deg, rgba(59,191,173,0.06), rgba(139,92,246,0.03))",
        "boxShadow": "inset 3px 0 0 #8B5CF6"
      },
      "toggleSwitch": { "layout": true, "springConfig": "bouncy" },
      "checkboxCheck": { "initial": { "scale": 0, "opacity": 0 }, "animate": { "scale": 1, "opacity": 1 }, "springConfig": "bouncy" },
      "dropdownOpen": {
        "initial": { "opacity": 0, "scale": 0.92, "y": -8, "filter": "blur(4px)" },
        "animate": { "opacity": 1, "scale": 1, "y": 0, "filter": "blur(0px)" },
        "exit": { "opacity": 0, "scale": 0.95, "y": -4, "filter": "blur(2px)" },
        "springConfig": "snappy"
      },
      "modalOpen": {
        "overlay": { "initial": { "opacity": 0, "backdropFilter": "blur(0px)" }, "animate": { "opacity": 1, "backdropFilter": "blur(8px)" }, "duration": 0.3 },
        "content": { "initial": { "opacity": 0, "scale": 0.88, "y": 30, "filter": "blur(8px)" }, "animate": { "opacity": 1, "scale": 1, "y": 0, "filter": "blur(0px)" }, "springConfig": "gentle" }
      },
      "toastSlide": {
        "initial": { "opacity": 0, "x": 80, "scale": 0.9, "filter": "blur(4px)" },
        "animate": { "opacity": 1, "x": 0, "scale": 1, "filter": "blur(0px)" },
        "exit": { "opacity": 0, "x": 80, "scale": 0.9 },
        "springConfig": "bouncy"
      },
      "pageTransition": {
        "initial": { "opacity": 0, "y": 12, "filter": "blur(4px)" },
        "animate": { "opacity": 1, "y": 0, "filter": "blur(0px)" },
        "exit": { "opacity": 0, "y": -8 },
        "duration": 0.3
      },
      "staggerChildren": { "staggerChildren": 0.04, "delayChildren": 0.08, "itemInitial": { "opacity": 0, "y": 8 }, "itemAnimate": { "opacity": 1, "y": 0 } },
      "numberTick": { "springConfig": "slow", "duration": 1.2 },
      "sidebarCollapse": { "expanded": { "width": 252 }, "collapsed": { "width": 64 }, "springConfig": "gentle" },
      "tabSwitch": { "layoutId": "activeTab", "springConfig": "snappy" },
      "dragReorder": { "dragElastic": 0.1, "whileDrag": { "scale": 1.03, "zIndex": 10 }, "springConfig": "bouncy" },
      "microBounce": { "animate": { "scale": [1, 1.15, 1] }, "duration": 0.4 },
